# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
DATABASE_URL=

# ─────────────────────────────────────────────
# Auth provider switch
# Values: replit | supabase
# Phase 1: keep as "replit"
# Phase 2+: switch to "supabase" after middleware is wired
# ─────────────────────────────────────────────
AUTH_PROVIDER=replit

# ─────────────────────────────────────────────
# Replit Auth (active in Phase 1)
# ─────────────────────────────────────────────
ISSUER_URL=https://replit.com/oidc
REPL_ID=
SESSION_SECRET=

# ─────────────────────────────────────────────
# Supabase Auth (active from Phase 2)
# Get these from your Supabase project → Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
