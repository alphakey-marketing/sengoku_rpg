# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
DATABASE_URL=

# ─── Auth provider switch ─────────────────────────────────────────────────────
# Set to "replit" during Phase 1.
# Switch to "supabase" after Phase 2 middleware is implemented.
AUTH_PROVIDER=replit

# ─── Replit Auth (active during Phase 1) ──────────────────────────────────────
ISSUER_URL=https://replit.com/oidc
REPL_ID=
SESSION_SECRET=

# ─── Supabase Auth (active from Phase 2 onward) ───────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
