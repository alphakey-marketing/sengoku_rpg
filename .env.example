# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
DATABASE_URL=

# ─────────────────────────────────────────────
# Auth provider
# Phase 5: Supabase is the default and only supported provider.
# Set to "replit" only if rolling back to the legacy integration.
# ─────────────────────────────────────────────
AUTH_PROVIDER=supabase

# ─────────────────────────────────────────────
# Supabase Auth — Server
# Get these from your Supabase project → Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Supabase Auth — Browser / Vite
# VITE_ prefix required so Vite exposes these to the frontend bundle.
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_AUTH_PROVIDER=supabase

# ─────────────────────────────────────────────
# Public URL — used for Supabase OAuth redirect
# Set to your deployed domain, e.g. https://yourapp.com
# ─────────────────────────────────────────────
PUBLIC_URL=

# ─────────────────────────────────────────────
# Legacy — Replit Auth (retired in Phase 5)
# Only needed if AUTH_PROVIDER=replit is set for rollback.
# ─────────────────────────────────────────────
# ISSUER_URL=https://replit.com/oidc
# REPL_ID=
# SESSION_SECRET=
# SUPABASE_ANON_KEY=
