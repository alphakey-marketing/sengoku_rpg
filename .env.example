# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
DATABASE_URL=

# ─────────────────────────────────────────────
# Auth provider switch
# Values: replit | supabase
# Phase 1: keep as "replit"
# Phase 2+: switch to "supabase" after middleware is wired
# ─────────────────────────────────────────────
AUTH_PROVIDER=replit

# ─────────────────────────────────────────────
# Replit Auth (active in Phase 1)
# ─────────────────────────────────────────────
ISSUER_URL=https://replit.com/oidc
REPL_ID=
SESSION_SECRET=

# ─────────────────────────────────────────────
# Supabase Auth — Server (active from Phase 2)
# Get these from your Supabase project → Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Supabase Auth — Browser / Vite client (active from Phase 2)
# VITE_ prefix required so Vite exposes these to the frontend bundle.
# Use the same values as SUPABASE_URL and SUPABASE_ANON_KEY above.
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_AUTH_PROVIDER=replit

# ─────────────────────────────────────────────
# Public URL (used for OAuth redirect in Phase 2)
# Set to your deployed domain, e.g. https://yourapp.com
# ─────────────────────────────────────────────
PUBLIC_URL=
