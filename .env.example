# =============================================
# Sengoku Chronicles — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ---- Database ----
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sengoku_rpg

# ---- Session ----
# Strong random string (min 32 chars). Generate with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-strong-random-secret

# ---- Replit Auth (only required when running on Replit) ----
ISSUER_URL=https://replit.com/oidc
REPL_ID=your-repl-id-here

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Docker Postgres (used by docker-compose.yml only) ----
POSTGRES_DB=sengoku_rpg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
